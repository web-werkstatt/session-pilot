#!/bin/bash
# Pre-Commit Hook: Dateigroessen + Secrets pruefen
# Installation: cp scripts/pre-commit .git/hooks/pre-commit

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m'
ERRORS=0

# === Dateigroessen-Limits ===
check_file_size() {
    local file="$1"
    local max_lines="$2"
    local filetype="$3"

    if [ ! -f "$file" ]; then
        return
    fi

    local lines
    lines=$(wc -l < "$file")
    if [ "$lines" -gt "$max_lines" ]; then
        echo -e "${RED}FEHLER:${NC} $file hat $lines Zeilen (Limit: $max_lines fuer $filetype)"
        ERRORS=$((ERRORS + 1))
    fi
}

# Nur staged Files pruefen
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

for file in $STAGED_FILES; do
    case "$file" in
        *.py)
            check_file_size "$file" 500 "Python"
            ;;
        *.tsx|*.jsx)
            check_file_size "$file" 300 "React"
            ;;
        *.ts|*.js)
            check_file_size "$file" 500 "TypeScript/JS"
            ;;
        *.css)
            check_file_size "$file" 400 "CSS"
            ;;
        *.scss)
            check_file_size "$file" 400 "SCSS"
            ;;
        *.html|*.astro)
            check_file_size "$file" 300 "HTML"
            ;;
    esac
done

# === Secrets-Check ===
SECRET_PATTERNS=(
    'PRIVATE.KEY'
    'password\s*=\s*["\x27][^"\x27]{8,}'
    'api[_-]?key\s*=\s*["\x27][^"\x27]{8,}'
    'token\s*=\s*["\x27][^"\x27]{8,}'
    'secret\s*=\s*["\x27][^"\x27]{8,}'
)

for file in $STAGED_FILES; do
    # Nur Textdateien pruefen, .env.example und Testdateien ausschliessen
    case "$file" in
        *.env.example|*test*|*.md|*.lock|*.json|scripts/pre-commit)
            continue
            ;;
    esac

    for pattern in "${SECRET_PATTERNS[@]}"; do
        if git diff --cached -- "$file" | grep -iP "^\+" | grep -qiP "$pattern"; then
            echo -e "${YELLOW}WARNUNG:${NC} Moegliches Secret in $file (Pattern: $pattern)"
            echo -e "  Bitte pruefen ob dies beabsichtigt ist."
            ERRORS=$((ERRORS + 1))
        fi
    done
done

# === .env Dateien blockieren ===
for file in $STAGED_FILES; do
    case "$file" in
        .env|*.env.local|*.env.production)
            echo -e "${RED}FEHLER:${NC} $file darf nicht committed werden!"
            ERRORS=$((ERRORS + 1))
            ;;
    esac
done

# === Architektur-Check (nur geaenderte Routes) ===
for file in $STAGED_FILES; do
    case "$file" in
        routes/*.py)
            # Kein subprocess in Routes
            if git diff --cached -- "$file" | grep -P "^\+.*import subprocess|^\+.*subprocess\." | grep -qv "^+++"; then
                echo -e "${YELLOW}WARNUNG:${NC} subprocess in $file - gehoert in services/"
            fi
            # Kein open() in Routes
            if git diff --cached -- "$file" | grep -P "^\+.*\bopen\(" | grep -qv "^+++"; then
                echo -e "${YELLOW}WARNUNG:${NC} Datei-I/O (open) in $file - gehoert in services/"
            fi
            ;;
    esac
done

# === Duplikat-Check: Globale Utilities ===
GLOBAL_UTILS="escapeHtml formatTimeAgo formatTokens formatDate formatDateTime"
for file in $STAGED_FILES; do
    case "$file" in
        static/js/*.js)
            [ "$(basename "$file")" = "base.js" ] && continue
            [ "$(basename "$file")" = "api.js" ] && continue
            for util in $GLOBAL_UTILS; do
                if git diff --cached -- "$file" | grep -qP "^\+.*function\s+$util\b"; then
                    echo -e "${YELLOW}WARNUNG:${NC} $util() in $file - bereits in base.js definiert"
                    ERRORS=$((ERRORS + 1))
                fi
            done
            ;;
    esac
done

# === Ergebnis ===
if [ $ERRORS -gt 0 ]; then
    echo ""
    echo -e "${RED}Pre-Commit: $ERRORS Problem(e) gefunden. Commit abgebrochen.${NC}"
    echo "Nutze 'git commit --no-verify' um den Check zu ueberspringen."
    exit 1
fi

exit 0
