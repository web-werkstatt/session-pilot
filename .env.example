# === Project Dashboard Konfiguration ===

# Gitea (Git-Server Integration)
GITEA_URL=https://git.example.com
GITEA_TOKEN=dein-gitea-api-token
GITEA_USER=dein-username

# PostgreSQL (für Claude Sessions)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=project_dashboard
DB_USER=dashboard
DB_PASSWORD=sicheres-passwort

# Dashboard Server
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5055

# Projekt-Verzeichnis (wo deine Projekte liegen)
DASHBOARD_PROJECTS_DIR=/mnt/projects
