# === SessionPilot Configuration ===

# Path to your projects directory
DASHBOARD_PROJECTS_DIR=/mnt/projects

# Dashboard Server
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5055

# PostgreSQL (required for Sessions, Timesheets, Usage Monitor)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=project_dashboard
DB_USER=dashboard
DB_PASSWORD=change-me

# Gitea (optional - Git server integration)
# GITEA_URL=https://git.example.com
# GITEA_TOKEN=your-api-token
# GITEA_USER=your-username
